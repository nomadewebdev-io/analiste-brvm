# ──────────────────────────────────────────────────────────────
#  Configuration de l'analyste IA (backend uniquement)
#  Copier ce fichier vers  server/.env  et y mettre la vraie clé.
#  Le fichier server/.env est ignoré par git (voir .gitignore).
#  La clé d'API ne doit JAMAIS apparaître côté frontend.
# ──────────────────────────────────────────────────────────────

# Port du serveur backend local
PORT=8787

# Clé d'API Anthropic. Récupérable sur https://console.anthropic.com
# NE JAMAIS committer la vraie valeur.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# Endpoint de l'API Messages.
# Par défaut l'API Anthropic. Modifiable pour router vers un proxy
# local compatible (ex. http://localhost:4000).
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Version de l'API Anthropic
ANTHROPIC_VERSION=2023-06-01

# Modèle utilisé par l'analyste
AI_MODEL=claude-sonnet-4-6

# Activer la recherche web (outil web_search). true / false
AI_WEB_SEARCH=true

# Nombre maximum de recherches web par message
AI_WEB_SEARCH_MAX_USES=5

# Nombre maximum de tokens dans la réponse de l'analyste (augmenter pour des analyses longues)
AI_MAX_TOKENS=2048

# URL du frontend en production (pour autoriser CORS depuis Netlify)
# Ex. : https://analiste-brvm.netlify.app
FRONTEND_URL=
